def consulta_simbolos():
    """ 1. SÍMBOLOS Y CONSTANTES MATEMÁTICAS """
    
    t = sp.Symbol('t')                                     # Variable normal t
    x = sp.Symbol('x', real=True)                          # Variable estrictamente real
    n = sp.Symbol('n', integer=True, positive=True)        # Variable entera y positiva (CRUCIAL para series)
    A, B, C = sp.symbols('A B C')                          # Crear múltiples variables a la vez

    pi_val = sp.pi      # El número pi (3.14159...)
    j_val = sp.I        # El número imaginario j (¡es una 'I' mayúscula!)
    inf_val = sp.oo     # Infinito (son dos letras 'o' minúsculas)


def consulta_funciones(t):
    """ 2. ESCRIBIENDO FUNCIONES MATEMÁTICAS """
    
    coseno = sp.cos(t)
    seno = sp.sin(t)
    exponencial = sp.exp(t)
    raiz = sp.sqrt(t)
    potencia = t**2     # ¡ATENCIÓN! En Python no se usa ^ para potencias, siempre usa **
    
    # Función por tramos (Piecewise)
    # Formato: (valor, condicion)
    # Ejemplo: f(t) vale 1 si 0 < t < 1, y vale 0 si t > 1
    f_tramos = sp.Piecewise( (1, (t > 0) & (t < 1)), (0, t > 1) )


def consulta_calculo_e_integrales(t, n):
    """ 3. CÁLCULO E INTEGRALES """
    
    # Integral definida
    # Formato: sp.integrate(funcion, (variable, limite_inf, limite_sup))
    integral = sp.integrate(t**2, (t, 0, sp.pi))
    
    # Símbolo de Sumatoria (solo dibuja el símbolo, no calcula numéricamente)
    # Formato: sp.Sum(termino_general, (variable, inicio, fin))
    sumatoria = sp.Sum(1/n, (n, 1, sp.oo))


