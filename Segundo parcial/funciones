def consulta_ecuaciones_y_sistemas():
    """ 5. ECUACIONES Y SISTEMAS (Para las EDOs) """
    
    A_n, B_n = sp.symbols('A_n B_n')
    
    # Plantear una ecuación: A_n + B_n = 5
    eq1 = sp.Eq(A_n + B_n, 5)
    
    # Resolver un sistema de ecuaciones
    solucion = sp.solve((eq1, eq1), (A_n, B_n))


def consulta_fasores_y_complejos():
    """ 6. NÚMEROS COMPLEJOS Y FASORES (Para Circuitos) """
    
    z = 3 + 4*sp.I
    
    parte_real = sp.re(z)       # Extrae el 3
    parte_imag = sp.im(z)       # Extrae el 4
    
    # Ángulo/fase correcto (toma en cuenta los cuadrantes matemáticos)
    # Formato: sp.atan2(imaginario, real)
    angulo = sp.atan2(parte_imag, parte_real)


